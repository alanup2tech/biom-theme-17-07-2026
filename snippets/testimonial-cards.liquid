{%- comment -%}
  Renders testimonial cards for a block.
  Accepts:
  - block: {Object}
  - layout: 'desktop' | 'mobile'
{%- endcomment -%}

{%- liquid
  assign video = block.settings.video
  assign video_url = block.settings.video_url
  assign video_source = block.settings.source | default: 'uploaded'
  assign has_video = false
  if video_source == 'url' and video_url != blank
    assign has_video = true
  elsif video != blank
    assign has_video = true
  endif

  assign testimonial_product = block.settings.product
  if testimonial_product == blank and block.settings.link != blank and block.settings.link contains '/products/'
    assign product_handle = block.settings.link | split: '/products/' | last | split: '?' | first | split: '#' | first
    assign testimonial_product = all_products[product_handle]
  endif

  assign testimonial_link = block.settings.link
  if testimonial_link == blank and testimonial_product != blank
    assign testimonial_link = testimonial_product.url
  endif
  if testimonial_link == blank
    assign testimonial_link = routes.all_products_collection_url
  endif
-%}

{%- if layout == 'mobile' -%}
  <div class="testimonial-mobile-slide" {{ block.shopify_attributes }}>
    <div class="testimonial-mobile-slide__main">
      <div class="testimonial-card testimonial-card--video testimonial-card--mobile">
        {%- if block.settings.image != blank -%}
          <img
            class="testimonial-card__poster"
            width="1000"
            height="750"
            src="{{ block.settings.image | image_url: width: 1000 }}"
            alt="{{ block.settings.name | escape }}"
            loading="lazy"
          >
        {%- elsif block.settings.image_asset != blank -%}
          <img
            class="testimonial-card__poster"
            width="600"
            height="450"
            src="{{ block.settings.image_asset | asset_url }}"
            alt="{{ block.settings.name | escape }}"
            loading="lazy"
          >
        {%- endif -%}

        {%- if has_video -%}
          <div class="testimonial-card__video">
            {%- if video_source == 'url' and video_url != blank -%}
              {%- liquid
                assign video_src = video_url
                if video_src contains 'youtube'
                  assign video_class = 'js-youtube'
                elsif video_src contains 'vimeo'
                  assign video_class = 'js-vimeo'
                endif
              -%}
              <iframe
                class="{{ video_class }}"
                src="{{ video_src }}"
                allow="autoplay; encrypted-media"
                allowfullscreen
                title="{{ block.settings.name | escape }}"
              ></iframe>
            {%- elsif video != blank -%}
              {{
                video
                | video_tag:
                  class: 'testimonial-video',
                  playsinline: true,
                  controls: true,
                  autoplay: false,
                  loop: false,
                  muted: false
              }}
            {%- endif -%}
          </div>
        {%- endif -%}

        <span class="testimonial-card__name">
          {{ block.settings.name }}
          {{ 'icon-verified.svg' | inline_asset_content }}
        </span>

        {%- if has_video -%}
          <button type="button" class="testimonial-card__play js-play-video" aria-label="Play video">
            {{ 'icon-play-circle.svg' | inline_asset_content }}
          </button>
        {%- endif -%}
      </div>

      <div class="testimonial-card testimonial-card--quote testimonial-card--mobile">
        <div class="testimonial-card__panel">
          <p class="testimonial-card__quote">&ldquo;{{ block.settings.quote }}&rdquo;</p>
          {% render 'testimonial-product-stars', product: testimonial_product, uid: block.id %}
        </div>
      </div>
    </div>

    <div class="testimonial-card testimonial-card--product">
      {%- if block.settings.product_image != blank -%}
        <img
          class="testimonial-card__product-img"
          width="300"
          height="225"
          src="{{ block.settings.product_image | image_url: width: 300 }}"
          alt=""
          loading="lazy"
        >
      {%- elsif block.settings.product_asset != blank -%}
        <img
          class="testimonial-card__product-img"
          width="600"
          height="450"
          src="{{ block.settings.product_asset | asset_url }}"
          alt=""
          loading="lazy"
        >
      {%- endif -%}

      <a
        class="testimonial-card__shop"
        href="{{ testimonial_link }}"
      >
        {{ block.settings.button_label | default: 'Shop Now' }}
      </a>
    </div>
  </div>
{%- else -%}
  <div class="testimonial-card testimonial-card--video" {{ block.shopify_attributes }}>
    {%- if block.settings.image != blank -%}
      <img
        class="testimonial-card__poster"
        width="1000"
        height="750"
        src="{{ block.settings.image | image_url: width: 1000 }}"
        alt="{{ block.settings.name | escape }}"
        loading="lazy"
      >
    {%- elsif block.settings.image_asset != blank -%}
      <img
        class="testimonial-card__poster"
        width="600"
        height="450"
        src="{{ block.settings.image_asset | asset_url }}"
        alt="{{ block.settings.name | escape }}"
        loading="lazy"
      >
    {%- endif -%}

    {%- if has_video -%}
      <div class="testimonial-card__video">
        {%- if video_source == 'url' and video_url != blank -%}
          {%- liquid
            assign video_src = video_url
            if video_src contains 'youtube'
              assign video_class = 'js-youtube'
            elsif video_src contains 'vimeo'
              assign video_class = 'js-vimeo'
            endif
          -%}
          <iframe
            class="{{ video_class }}"
            src="{{ video_src }}"
            allow="autoplay; encrypted-media"
            allowfullscreen
            title="{{ block.settings.name | escape }}"
          ></iframe>
        {%- elsif video != blank -%}
          {{
            video
            | video_tag:
              class: 'testimonial-video',
              playsinline: true,
              controls: true,
              autoplay: false,
              loop: false,
              muted: false
          }}
        {%- endif -%}
      </div>
    {%- endif -%}

    <span class="testimonial-card__name">
      {{ block.settings.name }}
      {{ 'icon-verified.svg' | inline_asset_content }}
    </span>

    {%- if has_video -%}
      <button type="button" class="testimonial-card__play js-play-video" aria-label="Play video">
        {{ 'icon-play-circle.svg' | inline_asset_content }}
      </button>
    {%- endif -%}
  </div>

  <div class="testimonial-card testimonial-card--quote">
    <div class="testimonial-card__panel">
      <p class="testimonial-card__quote">&ldquo;{{ block.settings.quote }}&rdquo;</p>

      {% render 'testimonial-product-stars', product: testimonial_product, uid: block.id %}

      <div class="testimonial-card__reveal">
        {%- if block.settings.product_image != blank -%}
          <img
            width="300"
            height="225"
            src="{{ block.settings.product_image | image_url: width: 300 }}"
            alt=""
            loading="lazy"
          >
        {%- elsif block.settings.product_asset != blank -%}
          <img
            width="600"
            height="450"
            src="{{ block.settings.product_asset | asset_url }}"
            alt=""
            loading="lazy"
          >
        {%- endif -%}

        <a
          class="testimonial-card__shop"
          href="{{ testimonial_link }}"
        >
          {{ block.settings.button_label | default: 'Shop Now' }}
        </a>
      </div>
    </div>
  </div>
{%- endif -%}
