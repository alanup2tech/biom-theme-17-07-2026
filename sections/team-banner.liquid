{{ 'section-team-banner.css' | asset_url | stylesheet_tag }}

<div class="team-banner color-{{ section.settings.color_scheme }}">
  <div class="team-banner__stripes" aria-hidden="true"></div>
  <div class="team-banner__glow" aria-hidden="true"></div>
  {%- if section.settings.background_image != blank -%}
    <img
      class="team-banner__image"
      width="2400"
      height="619"
      src="{{ section.settings.background_image | image_url: width: 2400 }}"
      alt=""
      loading="lazy"
    >
  {%- endif -%}
  <h1 class="team-banner__heading">{{ section.settings.heading }}</h1>
</div>

{% schema %}
{
  "name": "Page banner",
  "tag": "section",
  "class": "section-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Management Team" },
    { "type": "image_picker", "id": "background_image", "label": "Background image (optional, shown over the color scheme)" },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-4dae7f11-c26f-4c33-b52f-68ff3f5f7697"
    }
  ],
  "presets": [
    {
      "name": "Page banner",
      "settings": {
        "heading": "Management Team"
      }
    }
  ]
}
{% endschema %}
