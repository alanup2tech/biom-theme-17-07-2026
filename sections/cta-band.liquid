{{ 'section-content-bands.css' | asset_url | stylesheet_tag }}

<section class="cta-band noise">
  <h2 class="cta-band__heading reveal">{{ section.settings.heading }}</h2>
  {%- if section.settings.text != blank -%}
    <p class="cta-band__text reveal">{{ section.settings.text }}</p>
  {%- endif -%}
  <div class="cta-band__buttons reveal">
    {%- if section.settings.button1_label != blank -%}
      <a class="btn btn--lime" href="{{ section.settings.button1_link | default: routes.all_products_collection_url }}">
        {{ section.settings.button1_label }}
      </a>
    {%- endif -%}
    {%- if section.settings.button2_label != blank -%}
      <a class="btn" href="{{ section.settings.button2_link | default: '/pages/take-the-quiz' }}">
        {{ section.settings.button2_label }}
      </a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "CTA band",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Ready to Support Your Microbiome Ecosystem?" },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Explore the BIOM product line — each formula built on the same three-pillar science platform."
    },
    { "type": "text", "id": "button1_label", "label": "Button 1 label", "default": "Shop All Products" },
    { "type": "url", "id": "button1_link", "label": "Button 1 link" },
    { "type": "text", "id": "button2_label", "label": "Button 2 label", "default": "Find My Formula" },
    { "type": "url", "id": "button2_link", "label": "Button 2 link" }
  ],
  "presets": [{ "name": "CTA band" }]
}
{% endschema %}
