{{ 'section-leanbiom-highlight.css' | asset_url | stylesheet_tag }}

<section class="leanbiom-highlight noise">
  <div class="leanbiom-highlight__content">
    <div class="leanbiom-highlight__text reveal">
      <h2 class="leanbiom-highlight__heading">{{ section.settings.heading }}</h2>
      
      <div class="leanbiom-highlight__benefits">
        {%- for block in section.blocks -%}
          <div class="leanbiom-highlight__benefit" {{ block.shopify_attributes }}>
            <span class="leanbiom-highlight__icon">
              {%- if block.settings.icon != blank -%}
                <img src="{{ block.settings.icon | image_url: width: 96 }}" alt="" width="48" height="48" loading="lazy">
              {%- elsif block.settings.icon_asset != blank -%}
                <img src="{{ block.settings.icon_asset | asset_url }}" alt="" width="48" height="48" loading="lazy">
              {%- endif -%}
            </span>
            <span class="leanbiom-highlight__text">{{ block.settings.text }}</span>
          </div>
        {%- endfor -%}
      </div>

      <a class="btn" href="{{ section.settings.button_link | default: routes.all_products_collection_url }}">
        {{ section.settings.button_label }}
      </a>
    </div>

    <div class="leanbiom-highlight__media reveal">
      {%- if section.settings.image != blank -%}
        <img width="600" height="600" 
          src="{{ section.settings.image | image_url: width: 800 }}" 
          alt="{{ section.settings.image.alt | escape }}" 
          loading="lazy"
        >
      {%- else -%}
        <img width="600" height="600" 
          src="{{ 'product-leanbiom.png' | asset_url }}" 
          alt="LeanBiom" 
          loading="lazy"
        >
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "LeanBiom highlight",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "LeanBiom"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop LeanBiom"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Product image"
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "icon_asset",
          "label": "Icon asset filename",
          "info": "Theme asset used when no icon image is set"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Supports Lean Muscle Preservation"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LeanBiom highlight",
      "blocks": [
        { "type": "benefit", "settings": { "text": "Supports Lean Muscle Preservation", "icon_asset": "icon-benefit-muscle.svg" } },
        { "type": "benefit", "settings": { "text": "Eases GLP-1 Gut Side Effects", "icon_asset": "icon-benefit-gut.svg" } },
        { "type": "benefit", "settings": { "text": "Promotes Long-Term Weight Management", "icon_asset": "icon-benefit-weight.svg" } },
        { "type": "benefit", "settings": { "text": "Enhances GLP-1 Efficacy", "icon_asset": "icon-benefit-glp1.svg" } },
        { "type": "benefit", "settings": { "text": "Improves Gut Tolerance & Comfort", "icon_asset": "icon-benefit-comfort.svg" } }
      ]
    }
  ]
}
{% endschema %}
