{{ 'component-product-card.css' | asset_url | stylesheet_tag }}
{{ 'section-featured-products.css' | asset_url | stylesheet_tag }}

<section class="featured-products noise section section--full-width-margin section--page-width">
  <div class="page-width">
    <h2 class="featured-products__heading reveal">{{ section.settings.heading }}</h2>

    <div class="featured-products_list">
      <div class="swiper featureSwiper">
        <div class="swiper-wrapper">
          {%- liquid
            assign badge = section.settings.badge_text
            assign rendered = 0
          -%}
          {%- for block in section.blocks -%}
            {%- if block.settings.product != blank -%}
              {%- assign rendered = rendered | plus: 1 -%}
              {% render 'card-product', product: block.settings.product, badge: badge %}
            {%- endif -%}
          {%- endfor -%}

          {%- if rendered == 0 and section.settings.collection != blank -%}
            {%- for product in section.settings.collection.products -%}
              {%- assign rendered = rendered | plus: 1 -%}
              {% render 'card-product', product: product, badge: badge %}
            {%- endfor -%}
          {%- endif -%}
        </div>
        {% comment %} <div class="swiper-pagination"></div> {% endcomment %}
      </div>
      
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured products",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Most Popular Microbiome Systems"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "Subscribe & Save 15%"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection",
      "info": "Used when no product blocks are added (first 4 products)"
    }
  ],
  "presets": [{ "name": "Featured products" }]
}
{% endschema %}
