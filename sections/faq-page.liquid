<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div class="faq-page color-{{ section.settings.color_scheme }}">
  {% comment %} <div class="faq-page__hero">
    <div class="faq-page__hero-inner">
      {%- if section.settings.hero_title != blank -%}
        <h1 class="faq-page__hero-title">{{ section.settings.hero_title }}</h1>
      {%- endif -%}
    </div>
  </div> {% endcomment %}

  {%- render 'faq-page-sidebar' -%}

  <div class="faq-page__wrap">
    {%- assign category_number = 0 -%}

    {%- for block in section.blocks -%}
      {%- if block.type == 'category' -%}
        {%- assign category_number = category_number | plus: 1 -%}
        {%- assign question_offset = forloop.index -%}
        <div
          id="{{ block.settings.anchor_id | escape }}"
          class="faq-page__section{% if category_number > 1 %} faq-page__section--compact{% endif %}"
          {{ block.shopify_attributes }}
        >
          <div class="faq-page__row">
            <div class="faq-page__main">
              {%- if block.settings.title != blank -%}
                <h3 class="faq-page__category-title">{{ block.settings.title }}</h3>
              {%- endif -%}
              <div class="faq-page__accordion">
                {%- for question_block in section.blocks offset: question_offset -%}
                  {%- if question_block.type == 'category' -%}
                    {%- break -%}
                  {%- elsif question_block.type == 'question' -%}
                    <details class="faq-page__item" {{ question_block.shopify_attributes }}>
                      <summary class="faq-page__question">
                        <span class="faq-page__question-text">{{ question_block.settings.question }}</span>
                        <span class="faq-page__icon" aria-hidden="true">{{- 'icon-faq-caret.svg' | inline_asset_content -}}</span>
                      </summary>
                      {%- if question_block.settings.answer != blank -%}
                        <div class="faq-page__answer rte">
                          <div class="faq-page__answer-inner">
                            <p>{{ question_block.settings.answer }}</p>
                          </div>
                        </div>
                      {%- else -%}
                        <div class="faq-page__answer faq-page__answer--empty"></div>
                      {%- endif -%}
                    </details>
                  {%- endif -%}
                {%- endfor -%}
              </div>
            </div>
          </div>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

{% stylesheet %}
  .faq-page {
    padding-bottom: 60px;
    font-family: 'DM Sans', sans-serif;
    font-size: 18px;
    line-height: 1.65;
    color: var(--color-foreground, #1a1a2e);
  }

  .faq-page__hero {
    margin-top: -50px;
    padding: 30px 60px 0;
    background: #445438;
  }

  .faq-page__hero-inner {
    padding-block: 50px;
  }

  .faq-page__hero-title {
    margin: 0;
    color: #f9ffe3;
    font-family: var(--font-heading);
    font-size: clamp(2rem, 3vw, 3rem);
    font-weight: 700;
    line-height: 1.2;
    text-align: center;
    text-transform: uppercase;
  }

  .faq-page__wrap {
    padding-inline: 60px;
    max-width: 1840px;
    margin: 0 auto;
  }

  .faq-page__section {
    margin-top: 42px;
    scroll-margin-top: calc(var(--sticky-header-offset, 0px) + 90px);
  }

  .faq-page__section--compact {
    margin-top: 28px;
  }

  .faq-page__row {
    display: block;
  }

  .faq-page__main {
    padding-right: 2.56%;
  }

  .faq-page__category-title {
    margin: 0 0 16px;
    font-family: var(--font-heading);
    font-size: 20px;
    font-weight: 700;
    line-height: 1.35;
    color: #445438;
    text-align: left;
  }

  .faq-page__accordion {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .faq-page__item {
    border: 0;
    border-radius: 24px;
    background: #f7f7f5;
    overflow: hidden;
    transition: background-color 0.4s ease, box-shadow 0.4s ease;
  }

  .faq-page__item:last-child {
    border-bottom: 0;
  }

  .faq-page__question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    margin: 0;
    padding: 30px;
    list-style: none;
    cursor: pointer;
    color: #6f6f6f;
    font-family: 'DM Sans', sans-serif;
    font-size: 22px;
    font-weight: 700;
    line-height: 1.35;
    text-align: left;
  }

  .faq-page__question::-webkit-details-marker {
    display: none;
  }

  .faq-page__question:hover {
    background: #f9ffe3;
  }

  .faq-page__item[open] {
    background: #f3f5ef;
  }

  .faq-page__item[open] .faq-page__question {
    color: #7aa05f;
    font-weight: 700;
  }

  .faq-page__item[open] .faq-page__question:hover {
    background: transparent;
  }

  .faq-page__question-text {
    flex: 1;
  }

  .faq-page__icon {
    flex: 0 0 24px;
    width: 24px;
    height: 24px;
    position: relative;
    color: #7aa05f;
  }
  .faq-page__question:hover {
  background: transparent !important;
  color: #6f6f6f;
}
  /* .faq-page__icon::before,
  .faq-page__icon::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    background: currentColor;
    transform: translate(-50%, -50%);
  } */

  /* .faq-page__icon::before {
    width: 12px;
    height: 2px;
  } */

  /* .faq-page__icon::after {
    width: 2px;
    height: 12px;
    transition: transform 0.2s ease;
  } */

  .faq-page__icon svg {
    display: block;
    width: 100%;
    height: 100%;
    transform: rotate(0);
    transform-origin: center;
    transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .faq-page__item[open]:not(.is-closing) .faq-page__icon svg {
    transform: rotate(180deg);
  }
  /* .faq-page__item[open] .faq-page__icon::after {
    transform: translate(-50%, -50%) scaleY(0);
  } */

  .faq-page__answer {
    padding: 0 30px;
    color: #445438;
    font-family: 'DM Sans', sans-serif;
    font-size: 18px;
    line-height: 1.65;
    border-top: 0;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .faq-page__answer-inner {
    padding-bottom: 50px;
  }

  .faq-page__item[open] .faq-page__answer {
    color: #445438;
    background: #f3f5ef;
  }

  .faq-page__item[open]:not(.is-closing) .faq-page__answer {
    opacity: 1;
  }

  .faq-page__answer p {
    margin: 0;
    white-space: pre-line;
  }

  .faq-page__answer--empty {
    min-height: 0;
    padding: 0;
    border-top: none;
  }

  .faq-page__nav {
    position: sticky;
    top: var(--sticky-header-offset, 0);
    z-index: var(--layer-sticky, 10);
    background: #ffffff;
    border-bottom: 2px solid #445438;
  }

  body:has(#header-group #header-component[data-sticky-state='active']) .faq-page {
    --sticky-header-offset: var(--header-height);
  }

  .faq-page__nav-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 14px 60px;
    overflow-x: auto;
    background: #F9FFE3;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
  }

  .faq-page__nav-link {
    flex: 0 0 auto;
    padding: 10px 20px;
    border: 2px solid transparent;
    border-radius: 999px;
    background: #ffffff;
    color: #445438;
    font-family: 'DM Sans', sans-serif;
    font-size: 20px;
    font-weight: 400;
    line-height: 1.35;
    text-align: center;
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
  }

  .faq-page__nav-link:hover {
    background: #445438;
    color: #ffffff;
  }

  .faq-page__nav-link.is-active {
    border-color: #445438;
    background: #445438;
    color: #ffffff;
  }

  @media screen and (max-width: 989px) {
    .faq-page__wrap {
      padding-inline: 16px;
    }

    .faq-page__hero {
      margin-top: 0;
    }

    .faq-page__main {
      padding-right: 0;
    }

    .faq-page__section {
      margin-top: 32px;
    }

    .faq-page__question {
      padding: 22px 20px;
      font-size: 18px;
    }

    .faq-page__answer {
      padding: 0 20px;
    }

    .faq-page__answer-inner {
      padding-bottom: 38px;
    }

    .faq-page__nav-inner {
      display: block;
      padding: 12px 16px;
    }
    .faq-page__nav-link{
      line-height: 2.35;
    }
  }
{% endstylesheet %}

{% javascript %}
  document.addEventListener('DOMContentLoaded', function() {

    // Keep details content rendered until the height animation finishes.
    var faqInstances = new WeakMap();
    var reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

    class FaqAccordion {
      constructor(detail, group) {
        this.detail = detail;
        this.group = group;
        this.summary = detail.querySelector('summary');
        this.content = detail.querySelector('.faq-page__answer');
        this.animation = null;
        this.isClosing = false;
        this.isExpanding = false;

        if (!this.summary || !this.content) return;
        this.summary.addEventListener('click', this.handleClick.bind(this));
      }

      handleClick(event) {
        event.preventDefault();

        if (this.isClosing || !this.detail.open) {
          this.open();
        } else {
          this.close();
        }
      }

      open() {
        this.group.querySelectorAll('details.faq-page__item').forEach((other) => {
          if (other !== this.detail) faqInstances.get(other)?.close();
        });

        if (reduceMotion.matches) {
          this.finish(true);
          return;
        }

        var startHeight = this.detail.getBoundingClientRect().height;
        this.animation?.cancel();
        this.detail.style.height = startHeight + 'px';
        this.detail.style.overflow = 'hidden';
        this.detail.classList.remove('is-closing');
        this.detail.open = true;
        this.isClosing = false;
        this.isExpanding = true;

        window.requestAnimationFrame(() => {
          var endHeight = this.summary.offsetHeight + this.content.offsetHeight;
          this.animate(startHeight, endHeight, true);
        });
      }

      close() {
        if (!this.detail.open && !this.isExpanding) return;

        if (reduceMotion.matches) {
          this.finish(false);
          return;
        }

        var startHeight = this.detail.getBoundingClientRect().height;
        this.animation?.cancel();
        this.detail.style.height = startHeight + 'px';
        this.detail.style.overflow = 'hidden';
        this.detail.classList.add('is-closing');
        this.isClosing = true;
        this.isExpanding = false;
        this.animate(startHeight, this.summary.offsetHeight, false);
      }

      animate(startHeight, endHeight, expanded) {
        var animation = this.detail.animate(
          { height: [startHeight + 'px', endHeight + 'px'] },
          { duration: 560, easing: 'cubic-bezier(0.22, 1, 0.36, 1)' }
        );

        this.animation = animation;
        animation.onfinish = () => {
          if (this.animation === animation) this.finish(expanded);
        };
        animation.oncancel = () => {
          if (this.animation === animation) this.animation = null;
        };
      }

      finish(expanded) {
        this.detail.open = expanded;
        this.detail.classList.remove('is-closing');
        this.detail.style.removeProperty('height');
        this.detail.style.removeProperty('overflow');
        this.animation = null;
        this.isClosing = false;
        this.isExpanding = false;
      }
    }

    document.querySelectorAll('.faq-page__accordion').forEach(function(accordion) {
      accordion.querySelectorAll('details.faq-page__item').forEach(function(detail) {
        faqInstances.set(detail, new FaqAccordion(detail, accordion));
      });
    });

    // --- Nav: active state on scroll ---
    var nav = document.querySelector('.faq-page__nav');
    if (!nav) return;

    var links = nav.querySelectorAll('.faq-page__nav-link');
    var navSections = [];

    links.forEach(function(link) {
      var id = link.getAttribute('href').replace('#', '');
      var el = document.getElementById(id);
      if (el) navSections.push({ el: el, link: link });
    });

    if (!navSections.length) return;

    function updateActive() {
      var scrollY = window.scrollY + 120;
      var current = navSections[0];

      for (var i = 0; i < navSections.length; i++) {
        if (navSections[i].el.offsetTop <= scrollY) {
          current = navSections[i];
        }
      }

      links.forEach(function(l) { l.classList.remove('is-active'); });
      current.link.classList.add('is-active');
    }

    window.addEventListener('scroll', updateActive, { passive: true });
    updateActive();
  });
{% endjavascript %}

{% schema %}
{
  "name": "FAQ Page",
  "class": "section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "hero_title",
      "label": "Hero title",
      "default": "FREQUENTLY ASKED QUESTIONS"
    },
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "checkbox",
      "id": "show_nav",
      "label": "Show category navigation",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "FAQ category",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Category title"
        },
        {
          "type": "text",
          "id": "anchor_id",
          "label": "Anchor ID (for navigation links)",
          "info": "e.g. suppository, pH_test_kit, probiotics"
        }
      ]
    },
    {
      "type": "question",
      "name": "FAQ question",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer"
        }
      ]
    },
    {
      "type": "menu_item",
      "name": "Menu item",
      "limit": 10,
      "settings": [
        {
          "type": "text",
          "id": "nav_text",
          "label": "Menu text",
          "info": "Text shown in the navigation bar"
        },
        {
          "type": "text",
          "id": "anchor_id",
          "label": "Anchor ID",
          "info": "Must match the category's Anchor ID"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ Page"
    }
  ]
}
{% endschema %}
