<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }}"
>
  {% liquid
    assign total_blocks = section.blocks.size

    # Grid layout calculations
    assign grid_columns = total_blocks | at_most: 4

    # Calculate last row counts using modulo arithmetic
    # last_row_count = (total_blocks - 1) % N + 1
    assign last_row_count = total_blocks | minus: 1 | modulo: 4 | plus: 1
    assign tablet_last_row_count = total_blocks | minus: 1 | modulo: 2 | plus: 1

    # Check if there is an orphaned element (single item in last row)
    assign has_isolated_grid_item_desktop = false

    if total_blocks > 4 and last_row_count == 1
      assign has_isolated_grid_item_desktop = true
    endif
  %}
  <div
    class="
      footer-content
      spacing-style
      {% if has_isolated_grid_item_desktop %}footer-content--isolated-grid-item-desktop{% endif %}
    "
    style="
      {%  render 'spacing-style', settings: section.settings %}
      --footer-gap: {{ section.settings.gap }}px;
      --grid-columns: {{ grid_columns }};
      --last-row-count: {{ last_row_count }};
      --tablet-last-row-count: {{ tablet_last_row_count }};
    "
  >
    {% content_for 'blocks' %}
  </div>
</div>


<script>
(function() {
  const mq = matchMedia('(min-width: 750px) and (max-width: 989px)');
  const accordions = document.querySelectorAll('.footer-content accordion-custom');

  function applyTabletAccordion() {
    accordions.forEach(function(el) {
      var details = el.querySelector('details');
      if (!details) return;
      el.removeAttribute('data-disable-on-desktop');
      el.removeAttribute('open-by-default-on-desktop');
      details.open = false;
    });
  }

  function removeTabletAccordion() {
    accordions.forEach(function(el) {
      var details = el.querySelector('details');
      if (!details) return;
      el.setAttribute('data-disable-on-desktop', 'true');
      el.setAttribute('open-by-default-on-desktop', '');
      details.open = true;
    });
  }

  function handleMQ() {
    if (mq.matches) {
      applyTabletAccordion();
    } else {
      removeTabletAccordion();
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function() {
      handleMQ();
      mq.addEventListener('change', handleMQ);
    });
  } else {
    handleMQ();
    mq.addEventListener('change', handleMQ);
  }
})();
</script>

{% stylesheet %}
  .footer-content {
    contain: content;
    content-visibility: auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--footer-gap);
    align-items: start;
  }

  .footer-content .menu__heading__default {
    font-weight: var(--font-heading--weight);
  }

  @media screen and (max-width: 989px) {
    .footer-content .menu__heading__accordion {
      display: contents !important;
    }

    .footer-content .menu__heading__default {
      display: none !important;
    }

    .footer-content .menu__heading--empty {
      display: flex !important;
    }
  }

  @media screen and (min-width: 990px) {
    .footer-content {
      grid-template-columns: repeat(var(--grid-columns), 1fr);
    }

    /* Single item centered */
    .footer-content[style*='--grid-columns: 1'] {
      justify-items: center;
    }

    .footer-content--isolated-grid-item-desktop > :last-child {
      grid-column: 1 / -1;
    }
  }
{% endstylesheet %}

