<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div class="section section--full-width color-{{ section.settings.color_scheme }} why-biom-page">
  <div class="why-biom-page__article">
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'wb_hero' -%}
          <div class="why-biom-page__hero" {{ block.shopify_attributes }}>
            <div class="why-biom-page__hero-content">
              {%- if block.settings.heading != blank -%}
                <h1 class="why-biom-page__hero-heading">{{ block.settings.heading }}</h1>
              {%- endif -%}
            </div>
          </div>

        {%- when 'wb_intro_card' -%}
          <div class="why-biom-page__intro" {{ block.shopify_attributes }}>
            <div class="why-biom-page__intro-panel">
              {%- if block.settings.heading != blank -%}
                <h2 class="why-biom-page__intro-heading">{{ block.settings.heading }}</h2>
              {%- endif -%}
              {%- if block.settings.text != blank -%}
                <div class="why-biom-page__intro-text">{{ block.settings.text }}</div>
              {%- endif -%}
              {%- if block.settings.tip_text != blank -%}
                <div class="why-biom-page__intro-tip">
                  {%- if block.settings.tip_label != blank -%}
                    <p class="why-biom-page__intro-tip-label">{{ block.settings.tip_label }}</p>
                  {%- endif -%}
                  <div class="why-biom-page__intro-tip-text">{{ block.settings.tip_text }}</div>
                </div>
              {%- endif -%}
            </div>
            <div class="why-biom-page__intro-media">
              {%- if block.settings.image != blank -%}
                <img
                  src="{{ block.settings.image | image_url: width: 700 }}"
                  alt="{{ block.settings.image.alt | escape }}"
                  width="{{ block.settings.image.width }}"
                  height="{{ block.settings.image.height }}"
                  loading="lazy"
                >
              {%- endif -%}
            </div>
          </div>

        {%- when 'wb_tips_grid' -%}
          <div class="why-biom-page__tips-grid" {{ block.shopify_attributes }}>
            <div class="why-biom-page__tips-grid-heading">
              {{ block.settings.heading_text }}
            </div>

            <div class="why-biom-page__tips-grid-icon why-biom-page__tips-grid-icon-1">
              {%- if block.settings.icon_1 != blank -%}
                <img
                  src="{{ block.settings.icon_1 | image_url: width: 300 }}"
                  alt="{{ block.settings.icon_1.alt | escape }}"
                  width="{{ block.settings.icon_1.width }}"
                  height="{{ block.settings.icon_1.height }}"
                  loading="lazy"
                >
              {%- endif -%}
            </div>

            <div class="why-biom-page__tips-grid-card why-biom-page__tips-grid-card--top why-biom-page__tips-grid-tip-1">
              {%- if block.settings.tip_1_label != blank -%}
                <p class="why-biom-page__tips-grid-label">{{ block.settings.tip_1_label }}</p>
              {%- endif -%}
              <div class="why-biom-page__tips-grid-text">{{ block.settings.tip_1_text }}</div>
            </div>

            <div class="why-biom-page__tips-grid-card why-biom-page__tips-grid-card--left why-biom-page__tips-grid-tip-2">
              {%- if block.settings.tip_2_label != blank -%}
                <p class="why-biom-page__tips-grid-label">{{ block.settings.tip_2_label }}</p>
              {%- endif -%}
              <div class="why-biom-page__tips-grid-text">{{ block.settings.tip_2_text }}</div>
            </div>

            <div class="why-biom-page__tips-grid-icon why-biom-page__tips-grid-icon-2">
              {%- if block.settings.icon_2 != blank -%}
                <img
                  src="{{ block.settings.icon_2 | image_url: width: 300 }}"
                  alt="{{ block.settings.icon_2.alt | escape }}"
                  width="{{ block.settings.icon_2.width }}"
                  height="{{ block.settings.icon_2.height }}"
                  loading="lazy"
                >
              {%- endif -%}
            </div>
          </div>

        {%- when 'wb_bullet_bar' -%}
          <div class="why-biom-page__bullet-bar" {{ block.shopify_attributes }}>
            {{ block.settings.items }}
          </div>

        {%- when 'wb_functions_section' -%}
          <div class="why-biom-page__functions" {{ block.shopify_attributes }}>
            {%- if block.settings.heading != blank -%}
              <h2 class="why-biom-page__functions-heading">{{ block.settings.heading }}</h2>
            {%- endif -%}
            <div class="why-biom-page__functions-row">
              <div class="why-biom-page__functions-card">
                {%- for i in (1..3) -%}
                  {%- assign icon_key = 'category_' | append: i | append: '_icon' -%}
                  {%- assign title_key = 'category_' | append: i | append: '_title' -%}
                  {%- assign items_key = 'category_' | append: i | append: '_items' -%}
                  {%- assign cat_icon = block.settings[icon_key] -%}
                  {%- assign cat_title = block.settings[title_key] -%}
                  {%- assign cat_items = block.settings[items_key] -%}
                  <div class="why-biom-page__functions-category">
                    <div class="why-biom-page__functions-icon">
                      {%- if cat_icon != blank -%}
                        <img
                          src="{{ cat_icon | image_url: width: 100 }}"
                          alt=""
                          width="40"
                          height="40"
                          loading="lazy"
                        >
                      {%- endif -%}
                    </div>
                    {%- if cat_title != blank -%}
                      <p class="why-biom-page__functions-title">{{ cat_title }}</p>
                    {%- endif -%}
                    <div class="why-biom-page__functions-items">{{ cat_items }}</div>
                  </div>
                {%- endfor -%}
              </div>

              <div class="why-biom-page__functions-media">
                {%- if block.settings.body_image != blank -%}
                  <img
                    src="{{ block.settings.body_image | image_url: width: 500 }}"
                    alt="{{ block.settings.body_image.alt | escape }}"
                    width="{{ block.settings.body_image.width }}"
                    height="{{ block.settings.body_image.height }}"
                    loading="lazy"
                  >
                {%- endif -%}
              </div>

              <div class="why-biom-page__functions-card">
                {%- for i in (4..6) -%}
                  {%- assign icon_key = 'category_' | append: i | append: '_icon' -%}
                  {%- assign title_key = 'category_' | append: i | append: '_title' -%}
                  {%- assign items_key = 'category_' | append: i | append: '_items' -%}
                  {%- assign cat_icon = block.settings[icon_key] -%}
                  {%- assign cat_title = block.settings[title_key] -%}
                  {%- assign cat_items = block.settings[items_key] -%}
                  <div class="why-biom-page__functions-category">
                    <div class="why-biom-page__functions-icon">
                      {%- if cat_icon != blank -%}
                        <img
                          src="{{ cat_icon | image_url: width: 100 }}"
                          alt=""
                          width="40"
                          height="40"
                          loading="lazy"
                        >
                      {%- endif -%}
                    </div>
                    {%- if cat_title != blank -%}
                      <p class="why-biom-page__functions-title">{{ cat_title }}</p>
                    {%- endif -%}
                    <div class="why-biom-page__functions-items">{{ cat_items }}</div>
                  </div>
                {%- endfor -%}
              </div>
            </div>
          </div>

        {%- when 'wb_dysbiosis_grid' -%}
          <div class="why-biom-page__dysbiosis" {{ block.shopify_attributes }}>
            <div class="why-biom-page__dysbiosis-cell why-biom-page__dysbiosis-cell--left">
              <div class="why-biom-page__dysbiosis-text">{{ block.settings.text_1 }}</div>
              {%- if block.settings.image_1 != blank -%}
                <img
                  class="why-biom-page__dysbiosis-image"
                  src="{{ block.settings.image_1 | image_url: width: 400 }}"
                  alt="{{ block.settings.image_1.alt | escape }}"
                  width="{{ block.settings.image_1.width }}"
                  height="{{ block.settings.image_1.height }}"
                  loading="lazy"
                >
              {%- endif -%}
            </div>

            <div class="why-biom-page__dysbiosis-cell why-biom-page__dysbiosis-cell--center">
              {%- if block.settings.image_2 != blank -%}
                <img
                  class="why-biom-page__dysbiosis-image"
                  src="{{ block.settings.image_2 | image_url: width: 400 }}"
                  alt="{{ block.settings.image_2.alt | escape }}"
                  width="{{ block.settings.image_2.width }}"
                  height="{{ block.settings.image_2.height }}"
                  loading="lazy"
                >
              {%- endif -%}
              <div class="why-biom-page__dysbiosis-text">{{ block.settings.text_2 }}</div>
            </div>

            <div class="why-biom-page__dysbiosis-cell why-biom-page__dysbiosis-cell--center">
              <div class="why-biom-page__dysbiosis-statement">{{ block.settings.statement }}</div>
            </div>

            <div class="why-biom-page__dysbiosis-cell why-biom-page__dysbiosis-cell--center">
              {%- if block.settings.image_3 != blank -%}
                <img
                  class="why-biom-page__dysbiosis-image"
                  src="{{ block.settings.image_3 | image_url: width: 400 }}"
                  alt="{{ block.settings.image_3.alt | escape }}"
                  width="{{ block.settings.image_3.width }}"
                  height="{{ block.settings.image_3.height }}"
                  loading="lazy"
                >
              {%- endif -%}
            </div>
          </div>

        {%- when 'wb_diversify' -%}
          <div class="why-biom-page__diversify" {{ block.shopify_attributes }}>
            <div class="why-biom-page__diversify-row">
              <div class="why-biom-page__diversify-tip">
                {%- if block.settings.tip_label != blank -%}
                  <p class="why-biom-page__diversify-tip-label">{{ block.settings.tip_label }}</p>
                {%- endif -%}
                <div class="why-biom-page__diversify-tip-text">{{ block.settings.tip_text }}</div>
              </div>
              <div class="why-biom-page__diversify-side">
                {%- if block.settings.side_heading != blank -%}
                  <h3 class="why-biom-page__diversify-side-heading">{{ block.settings.side_heading }}</h3>
                {%- endif -%}
                <div class="why-biom-page__diversify-side-text">{{ block.settings.side_text }}</div>
              </div>
            </div>

            <h2 class="why-biom-page__diversify-banner">
              {{ block.settings.banner_heading }}
            </h2>

            {%- if block.settings.image != blank -%}
              <div class="why-biom-page__diversify-image">
                <img
                  src="{{ block.settings.image | image_url: width: 600 }}"
                  alt="{{ block.settings.image.alt | escape }}"
                  width="{{ block.settings.image.width }}"
                  height="{{ block.settings.image.height }}"
                  loading="lazy"
                >
              </div>
            {%- endif -%}
          </div>

        {%- when 'wb_badges_feature' -%}
          <div class="why-biom-page__badges-feature" {{ block.shopify_attributes }}>
            {%- if block.settings.heading != blank -%}
              <h2 class="why-biom-page__badges-feature-heading">{{ block.settings.heading }}</h2>
            {%- endif -%}
            <div class="why-biom-page__badges-feature-row">
              <div class="why-biom-page__badges-feature-badges">
                {%- if block.settings.badge_image != blank -%}
                  <img
                    src="{{ block.settings.badge_image | image_url: width: 400 }}"
                    alt="{{ block.settings.badge_image.alt | escape }}"
                    width="{{ block.settings.badge_image.width }}"
                    height="{{ block.settings.badge_image.height }}"
                    loading="lazy"
                  >
                {%- endif -%}
              </div>
              <div class="why-biom-page__badges-feature-text">
                {{ block.settings.text }}
              </div>
            </div>
          </div>

        {%- when 'wb_icon_bullets' -%}
          <div
            class="why-biom-page__icon-bullets why-biom-page__icon-bullets--icon-{{ block.settings.icon_position }}"
            {{ block.shopify_attributes }}
          >
            {%- if block.settings.heading != blank -%}
              <h2 class="why-biom-page__icon-bullets-heading">{{ block.settings.heading }}</h2>
            {%- endif -%}
            <div class="why-biom-page__icon-bullets-row">
              <div class="why-biom-page__icon-bullets-icon">
                {%- if block.settings.icon != blank -%}
                  <img
                    src="{{ block.settings.icon | image_url: width: 300 }}"
                    alt="{{ block.settings.icon.alt | escape }}"
                    width="{{ block.settings.icon.width }}"
                    height="{{ block.settings.icon.height }}"
                    loading="lazy"
                  >
                {%- endif -%}
              </div>
              <div class="why-biom-page__icon-bullets-list">
                {{ block.settings.items }}
              </div>
            </div>
          </div>

        {%- when 'wb_process_feature' -%}
          <div class="why-biom-page__process" {{ block.shopify_attributes }}>
            {%- if block.settings.heading != blank -%}
              <h2 class="why-biom-page__process-heading">{{ block.settings.heading }}</h2>
            {%- endif -%}
            <div class="why-biom-page__process-row">
              <div class="why-biom-page__process-media">
                {%- if block.settings.main_image != blank -%}
                  <img
                    class="why-biom-page__process-main-image"
                    src="{{ block.settings.main_image | image_url: width: 500 }}"
                    alt="{{ block.settings.main_image.alt | escape }}"
                    width="{{ block.settings.main_image.width }}"
                    height="{{ block.settings.main_image.height }}"
                    loading="lazy"
                  >
                {%- endif -%}
                <div class="why-biom-page__process-steps">
                  {%- for i in (1..4) -%}
                    {%- assign step_key = 'step_image_' | append: i -%}
                    {%- assign step_image = block.settings[step_key] -%}
                    <div class="why-biom-page__process-step">
                      {%- if step_image != blank -%}
                        <img
                          src="{{ step_image | image_url: width: 200 }}"
                          alt="{{ step_image.alt | escape }}"
                          width="{{ step_image.width }}"
                          height="{{ step_image.height }}"
                          loading="lazy"
                        >
                      {%- endif -%}
                    </div>
                  {%- endfor -%}
                </div>
              </div>
              <div class="why-biom-page__process-list">
                {{ block.settings.items }}
              </div>
            </div>
          </div>

        {%- when 'wb_tribiom' -%}
          <div class="why-biom-page__tribiom" {{ block.shopify_attributes }}>
            {%- if block.settings.statement != blank -%}
              <div class="why-biom-page__tribiom-statement">{{ block.settings.statement }}</div>
            {%- endif -%}
            <div class="why-biom-page__tribiom-box">
              {%- if block.settings.diagram_image != blank -%}
                <img
                  src="{{ block.settings.diagram_image | image_url: width: 900 }}"
                  alt="{{ block.settings.diagram_image.alt | escape }}"
                  width="{{ block.settings.diagram_image.width }}"
                  height="{{ block.settings.diagram_image.height }}"
                  loading="lazy"
                >
              {%- endif -%}
            </div>
          </div>

        {%- when 'wb_statement' -%}
          <div class="why-biom-page__statement" {{ block.shopify_attributes }}>
            {{ block.settings.text }}
          </div>

        {%- when 'wb_recommend_section' -%}
          <div class="why-biom-page__recommend" {{ block.shopify_attributes }}>
            {%- if block.settings.heading != blank -%}
              <h2 class="why-biom-page__recommend-heading">{{ block.settings.heading }}</h2>
            {%- endif -%}
            {%- if block.settings.subheading != blank -%}
              <div class="why-biom-page__recommend-subheading">{{ block.settings.subheading }}</div>
            {%- endif -%}

            <div class="why-biom-page__recommend-row">
              <div class="why-biom-page__recommend-list-1">{{ block.settings.list_1 }}</div>
              <div class="why-biom-page__recommend-col-2">
                {%- if block.settings.image != blank -%}
                  <div class="why-biom-page__recommend-image">
                    <img
                      src="{{ block.settings.image | image_url: width: 500 }}"
                      alt="{{ block.settings.image.alt | escape }}"
                      width="{{ block.settings.image.width }}"
                      height="{{ block.settings.image.height }}"
                      loading="lazy"
                    >
                  </div>
                {%- endif -%}
                <div class="why-biom-page__recommend-list-2">{{ block.settings.list_2 }}</div>
              </div>
            </div>

            <div class="why-biom-page__recommend-cards">
              {%- for i in (1..3) -%}
                {%- assign heading_key = 'card_' | append: i | append: '_heading' -%}
                {%- assign subheading_key = 'card_' | append: i | append: '_subheading' -%}
                {%- assign text_key = 'card_' | append: i | append: '_text' -%}
                {%- assign image_key = 'card_' | append: i | append: '_image' -%}
                {%- assign card_heading = block.settings[heading_key] -%}
                {%- assign card_subheading = block.settings[subheading_key] -%}
                {%- assign card_text = block.settings[text_key] -%}
                {%- assign card_image = block.settings[image_key] -%}
                <div class="why-biom-page__recommend-card">
                  {%- if card_heading != blank -%}
                    <p class="why-biom-page__recommend-card-heading">{{ card_heading }}</p>
                  {%- endif -%}
                  {%- if card_subheading != blank -%}
                    <p class="why-biom-page__recommend-card-subheading">{{ card_subheading }}</p>
                  {%- endif -%}
                  {%- if card_text != blank -%}
                    <p class="why-biom-page__recommend-card-text">{{ card_text }}</p>
                  {%- endif -%}
                  {%- if card_image != blank -%}
                    <div class="why-biom-page__recommend-card-media">
                      <img
                        src="{{ card_image | image_url: width: 400 }}"
                        alt="{{ card_image.alt | escape }}"
                        width="{{ card_image.width }}"
                        height="{{ card_image.height }}"
                        loading="lazy"
                      >
                    </div>
                  {%- endif -%}
                </div>
              {%- endfor -%}
            </div>
          </div>
      {%- endcase -%}
    {%- endfor -%}
  </div>
</div>

{% stylesheet %}
  .why-biom-page {
    --wb-section-gap: 90px;
    padding-block: 0;
    font-family: 'DM Sans', sans-serif;
    font-size: 18px;
    line-height: var(--font-paragraph--line-height);
    background: var(--color-background);
  }

  @media screen and (max-width: 1199px) {
    .why-biom-page {
      --wb-section-gap: 60px;
    }
  }

  @media screen and (max-width: 767px) {
    .why-biom-page {
      --wb-section-gap: 40px;
    }
  }

  .why-biom-page__article {
    width: 100%;
    max-width: 1200px;
    margin-inline: auto;
    box-sizing: border-box;
    padding-inline: 48px;
  }

  @media screen and (max-width: 1199px) {
    .why-biom-page__article {
      padding-inline: 24px;
    }
  }

  @media screen and (max-width: 767px) {
    .why-biom-page__article {
      padding-inline: 20px;
    }
  }

  /* Hero block: heading with an optional full-width background image.
     Breaks out of the article's max-width to stay full viewport width. */
  .why-biom-page__hero {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: clamp(220px, 22vw, 340px);
    padding: 40px 60px;
    overflow: hidden;
    width: 100vw;
    margin-inline: calc(50% - 50vw);
    background: #2c3a22;
  }

  .why-biom-page__hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 900px;
  }

  .why-biom-page__hero-heading {
    margin: 0;
    font-family: var(--font-heading);
    font-weight: 500;
    font-size: 36px;
    line-height: var(--font-h1--line-height);
    color: var(--color-white);
  }

  @media screen and (max-width: 767px) {
    .why-biom-page__hero {
      padding: 32px 20px;
    }
  }

  /* Intro card block (gradient panel + nested tip + side illustration) */
  .why-biom-page__intro {
    display: flex;
    align-items: stretch;
    gap: 40px;
    flex-wrap: wrap;
    margin-block: var(--wb-section-gap);
  }

  .why-biom-page__intro-panel {
    flex: 1 1 0;
    min-width: 320px;
    background: #7AA05F;
    border-radius: 24px;
    padding: 40px 48px 48px;
    box-shadow: 0 24px 40px -16px rgb(44 58 34 / 0.35);
  }

  .why-biom-page__intro-heading {
    margin: 0 0 20px;
    font-family: var(--font-heading);
    font-size: 28px;
    font-weight: 700;
    color: var(--color-white);
  }

  .why-biom-page__intro-text {
    color: var(--color-white);
    font-size: 18px;
    line-height: var(--font-paragraph--line-height);
  }

  .why-biom-page__intro-text p {
    margin: 0;
  }

  .why-biom-page__intro-text strong {
    color: var(--color-white);
  }

  .why-biom-page__intro-tip {
    margin-top: 24px;
    background: #f4f4f5;
    border-radius: 14px;
    padding: 24px 28px;
    box-shadow: 0 12px 24px -12px rgb(0 0 0 / 0.25);
  }

  .why-biom-page__intro-tip-label {
    margin: 0 0 10px;
    font-family: var(--font-heading);
    font-size: 16px;
    font-weight: 700;
    color: #2c3a22;
  }

  .why-biom-page__intro-tip-text {
    color: var(--color-foreground);
    font-size: 18px;
    line-height: var(--font-paragraph--line-height);
  }

  .why-biom-page__intro-tip-text p {
    margin: 0;
  }

  .why-biom-page__intro-media {
    flex: 1 1 0;
    min-width: 220px;
    min-height: 180px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .why-biom-page__intro-media img {
    width: auto;
    max-width: 100%;
    height: 100%;
    max-height: 100%;
    object-fit: contain;
    display: block;
  }

  @media screen and (max-width: 767px) {
    .why-biom-page__intro-panel {
      padding: 32px 24px 36px;
    }

    .why-biom-page__intro-media {
      flex-basis: 100%;
      margin-inline: auto;
    }

    .why-biom-page__intro-media img {
      width: 100%;
      max-width: 160px;
      height: auto;
      max-height: none;
    }
  }

  /* Tips grid block (heading + icon + tip / tip + icon, staggered two-row layout) */
  .why-biom-page__tips-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    column-gap: 32px;
    row-gap: 40px;
    align-items: center;
    margin-block: var(--wb-section-gap);
  }

  .why-biom-page__tips-grid-heading {
    grid-column: 1;
    grid-row: 1;
    color: var(--color-foreground);
    font-size: 18px;
    line-height: var(--font-paragraph--line-height);
  }

  .why-biom-page__tips-grid-heading p {
    margin: 0;
  }

  .why-biom-page__tips-grid-heading strong {
    color: var(--color-foreground);
  }

  .why-biom-page__tips-grid-icon {
    text-align: center;
  }

  .why-biom-page__tips-grid-icon img {
    width: 100%;
    max-width: 220px;
    height: auto;
    display: inline-block;
  }

  .why-biom-page__tips-grid-icon-1 {
    grid-column: 2;
    grid-row: 1;
  }

  .why-biom-page__tips-grid-icon-2 {
    grid-column: 3;
    grid-row: 2;
  }

  .why-biom-page__tips-grid-icon-2 img {
    max-width: 280px;
  }

  .why-biom-page__tips-grid-card {
