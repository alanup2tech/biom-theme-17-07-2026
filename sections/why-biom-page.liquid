    color: var(--color-white);
  }

  .why-biom-page__recommend-card-text {
    margin: 0 0 20px;
    font-weight: 400;
    font-size: 15px;
    text-transform: none;
    color: var(--color-white);
  }

  .why-biom-page__recommend-card-media img {
    width: 100%;
    max-width: 160px;
    height: 160px;
    object-fit: contain;
    display: inline-block;
  }

  @media screen and (max-width: 767px) {
    .why-biom-page__recommend-row {
      padding: 28px 24px;
      border-radius: 16px;
    }

    .why-biom-page__recommend-cards {
      flex-direction: column;
    }
  }

  /* Functions section block (heading, two dark cards of 3 stacked categories + center body image) */
  .why-biom-page__functions {
    margin-block: var(--wb-section-gap);
  }

  .why-biom-page__functions-heading {
    position: relative;
    margin: 0 0 40px;
    padding-bottom: 16px;
    text-align: center;
    font-family: var(--font-heading);
    font-size: 32px;
    font-weight: 700;
    color: var(--color-foreground-heading);
  }

  .why-biom-page__functions-heading::after {
    content: '';
    position: absolute;
    left: 50%;
    bottom: 0;
    width: 56px;
    height: 4px;
    border-radius: 2px;
    background: #7AA05F;
    transform: translateX(-50%);
  }

  .why-biom-page__functions-row {
    display: grid;
    grid-template-columns: 1fr 200px 1fr;
    grid-template-rows: repeat(3, auto);
    column-gap: 32px;
  }

  .why-biom-page__functions-card {
    display: grid;
    grid-template-rows: subgrid;
    grid-row: 1 / span 3;
    align-items: stretch;
    background: #7AA05F;
    border-radius: 20px;
    padding: 28px 24px;
    color: var(--color-white);
    box-shadow: 0 24px 48px -32px rgb(44 58 34 / 0.35);
  }

  .why-biom-page__functions-media {
    grid-row: 1 / span 3;
    align-self: center;
  }

  .why-biom-page__functions-media img {
    width: 100%;
    height: auto;
    display: block;
  }

  .why-biom-page__functions-category {
    padding-bottom: 20px;
    margin-bottom: 20px;
    border-bottom: 1px solid rgb(255 255 255 / 0.15);
    text-align: center;
  }

  .why-biom-page__functions-category:last-child {
    margin-bottom: 0;
    padding-bottom: 0;
    border-bottom: none;
  }

  .why-biom-page__functions-icon {
    width: 56px;
    height: 56px;
    margin: 0 auto 12px;
    border-radius: 50%;
    border: 2px solid var(--color-white);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .why-biom-page__functions-icon img {
    width: 28px;
    height: 28px;
    display: block;
  }

  .why-biom-page__functions-title {
    margin: 0 0 12px;
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    text-align: center;
    color: var(--color-white);
  }

  .why-biom-page__functions-items ul {
    list-style: none;
    margin: 0;
    padding: 0;
    text-align: left;
  }

  .why-biom-page__functions-items li {
    position: relative;
    padding-left: 20px;
    margin-bottom: 10px;
    font-size: 18px;
    line-height: var(--font-paragraph--line-height);
    color: #e8f1f8;
  }

  .why-biom-page__functions-items li:last-child {
    margin-bottom: 0;
  }

  .why-biom-page__functions-items li::before {
    content: '\00bb';
    position: absolute;
    left: 0;
    top: 0;
    color: var(--color-white);
    font-weight: 700;
  }

  @media screen and (max-width: 1199px) {
    .why-biom-page__functions-row {
      grid-template-columns: 1fr 180px 1fr;
    }
  }

  @media screen and (max-width: 767px) {
    .why-biom-page__functions-row {
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .why-biom-page__functions-card {
      display: block;
      width: 100%;
    }

    .why-biom-page__functions-media {
      width: 90px;
    }
  }

  /* Larger section headings on desktop */
  @media screen and (min-width: 1200px) {
    .why-biom-page__functions-heading,
    .why-biom-page__process-heading,
    .why-biom-page__badges-feature-heading,
    .why-biom-page__icon-bullets-heading,
    .why-biom-page__recommend-heading,
    .why-biom-page__diversify-banner {
      font-size: 42px;
    }
  }
{% endstylesheet %}

{% schema %}
