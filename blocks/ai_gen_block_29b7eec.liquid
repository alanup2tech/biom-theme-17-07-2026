{% doc %}
  @prompt
    Create a production-ready Shopify blog pagination component using Shopify Liquid, HTML, and CSS.
    
    The attached image is only a visual design reference. Do not copy exact dimensions, colors, spacing, border radius, or typography values from it. Instead, recreate the same overall visual style and user experience using clean, modern, responsive design principles.
    
    Requirements
    Use Shopify's native pagination with Liquid.
    Support Previous and Next navigation.
    Display page numbers.
    Highlight the active page.
    Automatically disable Previous on the first page and Next on the last page.
    Keep pagination centered.
    Fully responsive across desktop, tablet, and mobile.
    Smooth hover and active state transitions.
    Use semantic HTML and accessible markup (aria-label, aria-current, keyboard focus styles).
    Preserve all pagination URLs generated by Shopify.
    Do not use JavaScript for pagination.
    Shopify Integration
    
    Use Shopify's native pagination:
    
    {% paginate blog.articles by section.settings.posts_per_page %}
    
    The pagination must work with Shopify's built-in pagination object and not rely on any custom logic.
    
    Code Quality
    Production-ready code
    Clean, modular Liquid
    Well-structured CSS
    No inline styles
    No unnecessary JavaScript
    Compatible with Shopify OS 2.0 and Dawn/custom themes
    Output
    
    Provide:
    
    Complete Liquid markup for the pagination.
    Complete CSS.
    Any required schema updates.
    Instructions on where the code should be added.
    Design Guidance
    
    The attached image serves only as inspiration for the overall layout and appearance. Create a polished, modern pagination component that naturally fits into a professional Shopify blog theme rather than reproducing the image pixel-for-pixel.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-blog-pagination-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    margin: {{ block.settings.spacing_top }}px 0 {{ block.settings.spacing_bottom }}px;
  }

  .ai-blog-pagination__wrapper-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: {{ block.settings.gap }}px;
    flex-wrap: wrap;
  }

  .ai-blog-pagination__item-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: {{ block.settings.button_size }}px;
    height: {{ block.settings.button_size }}px;
    padding: 0 {{ block.settings.button_padding }}px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    text-decoration: none;
    font-size: {{ block.settings.font_size }}px;
    font-weight: {{ block.settings.font_weight }};
    transition: all 0.3s ease;
    cursor: pointer;
  }

  .ai-blog-pagination__item-{{ ai_gen_id }}:hover:not(.ai-blog-pagination__item--disabled-{{ ai_gen_id }}):not(.ai-blog-pagination__item--active-{{ ai_gen_id }}) {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
    transform: translateY(-2px);
  }

  .ai-blog-pagination__item-{{ ai_gen_id }}:focus-visible {
    outline: 2px solid {{ block.settings.button_text_color }};
    outline-offset: 2px;
  }

  .ai-blog-pagination__item--active-{{ ai_gen_id }} {
    background-color: {{ block.settings.active_background }};
    color: {{ block.settings.active_text_color }};
    border-color: {{ block.settings.active_border_color }};
    cursor: default;
    font-weight: 600;
  }

  .ai-blog-pagination__item--disabled-{{ ai_gen_id }} {
    background-color: {{ block.settings.disabled_background }};
    color: {{ block.settings.disabled_text_color }};
    border-color: {{ block.settings.disabled_border_color }};
    cursor: not-allowed;
    opacity: 0.5;
  }

  .ai-blog-pagination__arrow-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .ai-blog-pagination__arrow-icon-{{ ai_gen_id }} {
    width: 16px;
    height: 16px;
    stroke: currentColor;
    stroke-width: 2;
    fill: none;
  }

  .ai-blog-pagination__ellipsis-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: {{ block.settings.button_size }}px;
    height: {{ block.settings.button_size }}px;
    color: {{ block.settings.button_text_color }};
    font-size: {{ block.settings.font_size }}px;
    cursor: default;
  }

  @media screen and (max-width: 749px) {
    .ai-blog-pagination__wrapper-{{ ai_gen_id }} {
      gap: {{ block.settings.gap | times: 0.7 }}px;
    }

    .ai-blog-pagination__item-{{ ai_gen_id }} {
      min-width: {{ block.settings.button_size | times: 0.9 }}px;
      height: {{ block.settings.button_size | times: 0.9 }}px;
      padding: 0 {{ block.settings.button_padding | times: 0.8 }}px;
      font-size: {{ block.settings.font_size | times: 0.9 }}px;
    }

    .ai-blog-pagination__ellipsis-{{ ai_gen_id }} {
      min-width: {{ block.settings.button_size | times: 0.9 }}px;
      height: {{ block.settings.button_size | times: 0.9 }}px;
      font-size: {{ block.settings.font_size | times: 0.9 }}px;
    }

    {% if block.settings.hide_page_numbers_mobile %}
      .ai-blog-pagination__item--number-{{ ai_gen_id }} {
        display: none;
      }
      .ai-blog-pagination__ellipsis-{{ ai_gen_id }} {
        display: none;
      }
    {% endif %}
  }
{% endstyle %}

{% if paginate.pages > 1 %}
  <nav
    class="ai-blog-pagination-{{ ai_gen_id }}"
    role="navigation"
    aria-label="Blog pagination"
    {{ block.shopify_attributes }}
  >
    <div class="ai-blog-pagination__wrapper-{{ ai_gen_id }}">
      {% if paginate.previous %}
        <a
          href="{{ paginate.previous.url }}"
          class="ai-blog-pagination__item-{{ ai_gen_id }} ai-blog-pagination__arrow-{{ ai_gen_id }}"
          aria-label="Previous page"
        >
          <svg
            class="ai-blog-pagination__arrow-icon-{{ ai_gen_id }}"
            viewBox="0 0 24 24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
          {% if block.settings.show_prev_next_text %}
            <span>{{ block.settings.previous_text }}</span>
          {% endif %}
        </a>
      {% else %}
        <span
          class="ai-blog-pagination__item-{{ ai_gen_id }} ai-blog-pagination__item--disabled-{{ ai_gen_id }} ai-blog-pagination__arrow-{{ ai_gen_id }}"
          aria-label="Previous page (disabled)"
          aria-disabled="true"
        >
          <svg
            class="ai-blog-pagination__arrow-icon-{{ ai_gen_id }}"
            viewBox="0 0 24 24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
          {% if block.settings.show_prev_next_text %}
            <span>{{ block.settings.previous_text }}</span>
          {% endif %}
        </span>
      {% endif %}

      {% assign max_visible_pages = block.settings.max_visible_pages %}
      {% assign half_visible = max_visible_pages | divided_by: 2 %}
      {% assign start_page = paginate.current_page | minus: half_visible %}
      {% assign end_page = paginate.current_page | plus: half_visible %}

      {% if start_page < 1 %}
        {% assign start_page = 1 %}
        {% assign end_page = max_visible_pages %}
      {% endif %}

      {% if end_page > paginate.pages %}
        {% assign end_page = paginate.pages %}
        {% assign start_page = paginate.pages | minus: max_visible_pages | plus: 1 %}
        {% if start_page < 1 %}
          {% assign start_page = 1 %}
        {% endif %}
      {% endif %}

      {% if start_page > 1 %}
        <a
          href="{{ paginate.parts.first.url }}"
          class="ai-blog-pagination__item-{{ ai_gen_id }} ai-blog-pagination__item--number-{{ ai_gen_id }}"
          aria-label="Page 1"
        >
          1
        </a>
        {% if start_page > 2 %}
          <span class="ai-blog-pagination__ellipsis-{{ ai_gen_id }}" aria-hidden="true">...</span>
        {% endif %}
      {% endif %}

      {% for i in (start_page..end_page) %}
        {% if i == paginate.current_page %}
          <span
            class="ai-blog-pagination__item-{{ ai_gen_id }} ai-blog-pagination__item--active-{{ ai_gen_id }} ai-blog-pagination__item--number-{{ ai_gen_id }}"
            aria-label="Page {{ i }}"
            aria-current="page"
          >
            {{ i }}
          </span>
        {% else %}
          {% assign page_url = paginate.parts[i].url %}
          <a
            href="{{ page_url }}"
            class="ai-blog-pagination__item-{{ ai_gen_id }} ai-blog-pagination__item--number-{{ ai_gen_id }}"
            aria-label="Page {{ i }}"
          >
            {{ i }}
          </a>
        {% endif %}
      {% endfor %}

      {% if end_page < paginate.pages %}
        {% assign pages_minus_one = paginate.pages | minus: 1 %}
        {% if end_page < pages_minus_one %}
          <span class="ai-blog-pagination__ellipsis-{{ ai_gen_id }}" aria-hidden="true">...</span>
        {% endif %}
        <a
          href="{{ paginate.parts.last.url }}"
          class="ai-blog-pagination__item-{{ ai_gen_id }} ai-blog-pagination__item--number-{{ ai_gen_id }}"
          aria-label="Page {{ paginate.pages }}"
        >
          {{ paginate.pages }}
        </a>
      {% endif %}

      {% if paginate.next %}
        <a
          href="{{ paginate.next.url }}"
          class="ai-blog-pagination__item-{{ ai_gen_id }} ai-blog-pagination__arrow-{{ ai_gen_id }}"
          aria-label="Next page"
        >
          {% if block.settings.show_prev_next_text %}
            <span>{{ block.settings.next_text }}</span>
          {% endif %}
          <svg
            class="ai-blog-pagination__arrow-icon-{{ ai_gen_id }}"
            viewBox="0 0 24 24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        </a>
      {% else %}
        <span
          class="ai-blog-pagination__item-{{ ai_gen_id }} ai-blog-pagination__item--disabled-{{ ai_gen_id }} ai-blog-pagination__arrow-{{ ai_gen_id }}"
          aria-label="Next page (disabled)"
          aria-disabled="true"
        >
          {% if block.settings.show_prev_next_text %}
            <span>{{ block.settings.next_text }}</span>
          {% endif %}
          <svg
            class="ai-blog-pagination__arrow-icon-{{ ai_gen_id }}"
            viewBox="0 0 24 24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        </span>
      {% endif %}
    </div>
  </nav>
{% endif %}

{% schema %}
{
  "name": "Blog pagination",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "max_visible_pages",
      "label": "Maximum visible page numbers",
      "min": 3,
      "max": 9,
      "step": 2,
      "default": 5,
      "info": "Number of page buttons to show at once"
    },
    {
      "type": "range",
      "id": "spacing_top",
      "label": "Top spacing",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "spacing_bottom",
      "label": "Bottom spacing",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between buttons",
      "min": 4,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Button style"
    },
    {
      "type": "range",
      "id": "button_size",
      "label": "Button size",
      "min": 32,
      "max": 56,
      "step": 2,
      "unit": "px",
      "default": 44
    },
    {
      "type": "range",
      "id": "button_padding",
      "label": "Button padding",
      "min": 8,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 50,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "button_border_width",
      "label": "Border width",
      "min": 0,
      "max": 4,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Font weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi-bold"
        }
      ],
      "default": "500"
    },
    {
      "type": "header",
      "content": "Previous and next buttons"
    },
    {
      "type": "checkbox",
      "id": "show_prev_next_text",
      "label": "Show text labels",
      "default": false
    },
    {
      "type": "text",
      "id": "previous_text",
      "label": "Previous text",
      "default": "Previous"
    },
    {
      "type": "text",
      "id": "next_text",
      "label": "Next text",
      "default": "Next"
    },
    {
      "type": "header",
      "content": "Mobile"
    },
    {
      "type": "checkbox",
      "id": "hide_page_numbers_mobile",
      "label": "Hide page numbers on mobile",
      "default": false,
      "info": "Show only Previous and Next buttons on mobile"
    },
    {
      "type": "header",
      "content": "Default button colors"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Text",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_border_color",
      "label": "Border",
      "default": "#eae8e6"
    },
    {
      "type": "header",
      "content": "Hover state colors"
    },
    {
      "type": "color",
      "id": "button_hover_background",
      "label": "Background",
      "default": "#f5f5f5"
    },
    {
      "type": "color",
      "id": "button_hover_text_color",
      "label": "Text",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_hover_border_color",
      "label": "Border",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Active page colors"
    },
    {
      "type": "color",
      "id": "active_background",
      "label": "Background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "active_text_color",
      "label": "Text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "active_border_color",
      "label": "Border",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Disabled button colors"
    },
    {
      "type": "color",
      "id": "disabled_background",
      "label": "Background",
      "default": "#f5f5f5"
    },
    {
      "type": "color",
      "id": "disabled_text_color",
      "label": "Text",
      "default": "#999999"
    },
    {
      "type": "color",
      "id": "disabled_border_color",
      "label": "Border",
      "default": "#e6e6e6"
    }
  ],
  "presets": [
    {
      "name": "Blog pagination"
    }
  ]
}
{% endschema %}
